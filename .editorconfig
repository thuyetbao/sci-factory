# EditorConfig is awesome: https://EditorConfig.org

root = true

[*]
charset = utf-8
# end_of_line = lf
insert_final_newline = true

[*.md]
indent_style = space
indent_size = 2

[*.py]
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab
indent_size = 4

[*.{yaml,yml,json}]
indent_style = space
indent_size = 2
